# Copy this file to .env.local and edit as needed.
# .env.local is gitignored and never committed.

# Override the data/model CDN base URL.
# Default (unset): live GCS bucket reads whatever is currently published.
# Set to "" to run fully offline using your local make app-data export:
#   cp app/.env.local.example app/.env.local   (then uncomment below)
#   make app-data
#   make app-dev
#
# VITE_DATA_BASE=

# Or point at a staging bucket:
# VITE_DATA_BASE=https://storage.googleapis.com/off-the-pace-cdn-staging
