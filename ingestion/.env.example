# FastF1 + Ingestion Configuration
# Copy this file to .env and fill in your credentials

# === REQUIRED ===

# FastF1 (optional but recommended for faster caching)
# Get API key at: https://www.ergast.com/mrd/
# Note: FastF1 itself requires no authentication; Ergast key is optional
# ERGAST_API_KEY=your-ergast-api-key-here

# === OPTIONAL ===

# FastF1 Cache Directory
# Location where FastF1 stores downloaded session data (saves time on re-runs)
# Default: data/cache/
FASTF1_CACHE_DIR=/tmp/fastf1_cache

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
INGESTION_LOG_LEVEL=INFO

# Ingestion Timeout
# Per-request timeout in seconds (increase if running on slow network)
# Default: 300 (5 minutes)
INGESTION_TIMEOUT_SECONDS=300

# === Fabric Eventstream (optional) ===

# Azure Event Hub connection string (for replay_simulator.py)
# Format: Endpoint=sb://....servicebus.windows.net/;SharedAccessKeyName=...;SharedAccessKey=...
# AZURE_EVENT_HUB_CONN_STRING=your-event-hub-connection-string

# Event Hub topic name
# AZURE_EVENT_HUB_TOPIC=f1_laps
